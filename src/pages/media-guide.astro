---
import Layout from '@/layouts/Layout.astro';

// ── Types ─────────────────────────────────────────────────────────────────
interface GearItem  { lens:  string; use: string; }
interface LightItem { light: string; use: string; }
interface OffloadWindow {
  offload: string; neon: string; jarrod: string; breakPoint: string; notes: string;
}

// ── Gear Data ─────────────────────────────────────────────────────────────
const neonLenses: GearItem[] = [
  { lens: 'Sigma 18-35mm f/1.8',   use: 'Crowd shots, venue/atmosphere, fursuit walk group & wide stage shots.' },
  { lens: 'Canon 24-105mm f/4',    use: 'Versatile walkabout and general coverage — panels, dealers den, meetups.' },
  { lens: 'Canon 70-300mm f/4-5.6',use: 'Stage performances from distance, dance competition, talent show, candid fursuit portraits.' },
  { lens: 'Canon 50mm f/1.8',      use: 'Low-light candids, DJ sets, hallway fursuit portraits — lightweight carry option.' },
  { lens: 'Sigma 85mm f/1.4',      use: 'Fursuit portraits, subject isolation, shallow depth-of-field character shots.' },
];
const neonLights: LightItem[] = [
  { light: 'Godox V1 Pro Flash',   use: 'Primary flash for panels, meetups, costume competition, dim indoor spaces. Use with diffuser.' },
  { light: 'Aputure MC',           use: 'Constant light fill for close-up portraits and detail shots. Also useful as practical lighting accent.' },
];

const jarrodLenses: GearItem[] = [
  { lens: 'Tamron 28-75mm f/2.8',    use: 'Workhorse zoom — panels, general stills, interviews, walkabout coverage.' },
  { lens: 'Sigma 85mm f/1.4',        use: 'Fursuit portraits, subject isolation, low-light close-ups.' },
  { lens: 'Sony 70-200mm f/2.8 GM',  use: 'Stage performances, competitions, reaction shots, ceremony close-ups.' },
];
const jarrodLights: LightItem[] = [
  { light: 'Amaran Ray 120c + Octadome 60', use: 'Primary large softbox light — key light for interviews, talking heads, and portrait setups.' },
  { light: '2× Amaran Pano 60c',            use: 'Wide-area fill / background wash. Useful for multi-subject group shots, stage behind-the-scenes setups.' },
  { light: 'Amaran Ace 25c',               use: 'Compact accent/fill light — on-camera or off for run-and-gun video.' },
];
const neonSupplied = [
  { gear: 'FurDU-issued SD cards', use: 'Backup/swap cards — slower write speed than personal cards. Use your own high-speed cards as primary; rotate to these when personal cards are full. Return to ConOps after last con offload on Day 3.' },
];
const jarrodSupplied = [
  { gear: 'Flycam Flowline Pro Stabilizer (5–12 kg)',  use: 'Moving/tracking video — Fursuit Walk, Floor Wars, DJ roam shots. Balance before each shoot day.' },
  { gear: 'RØDE VideoMic ProPlus',                      use: 'On-camera audio for all video work. Engage high-pass filter outdoors. Charge nightly at hotel room or ConOps.' },
  { gear: 'Atomos Shinobi II + SmallRig Cage + Micro HDMI', use: 'On-camera monitor for critical video events. Charge Shinobi nightly at hotel room or ConOps.' },
  { gear: 'NEEWER 74" Pro Video Tripod',                  use: 'Locked-off static wide/medium shot for ceremony recordings.' },
  { gear: 'FurDU-issued SD cards', use: 'Backup/swap cards — slower write speed. Use own high-speed cards as primary. Return to ConOps after last con offload on Day 3.' },
];

// ── Offload Windows ───────────────────────────────────────────────────────
const offloadFri: OffloadWindow[] = [
  { offload: '1',        neon: '12:30–12:45 PM', jarrod: '12:45–1:00 PM',  breakPoint: 'Lunch after Dealers Den / morning coverage',      notes: 'High priority — 2.5 hrs of morning footage.' },
  { offload: '2',        neon: '4:30–4:45 PM',   jarrod: '4:45–5:00 PM',   breakPoint: 'After Dance Competition ends (4:30 PM)',           notes: 'Priority — transfer all footage before Opening Words at 5 PM.' },
  { offload: '3',        neon: '6:15–6:35 PM',   jarrod: '6:30–6:50 PM',   breakPoint: 'After Opening Words ends (6 PM)',                  notes: 'Priority — overlapping stagger; ceremony footage on cards.' },
  { offload: '4',        neon: '9:30–9:45 PM',   jarrod: '9:15–9:30 PM',   breakPoint: 'DJ transition — Pup Riff → Salty (9 PM)',         notes: 'Jarrod goes first; Neon holds photo solo until 9:30.' },
  { offload: '5 (wrap)', neon: '11:30–11:50 PM', jarrod: '12:00–12:20 AM', breakPoint: 'After Diesel set — end of night',                  notes: 'Neon wraps for the night; Jarrod continues closing video solo.' },
];
const offloadSat: OffloadWindow[] = [
  { offload: '1',        neon: '12:45–1:00 PM',  jarrod: '1:00–1:15 PM',   breakPoint: 'Post-Fursuit Walk lunch break',                    notes: 'Critical — Fursuit Walk generates highest file volume of the con.' },
  { offload: '2',        neon: '5:00–5:15 PM',   jarrod: '5:15–5:30 PM',   breakPoint: 'After From Garment to Fursuit ends (5 PM)',        notes: 'Priority — must offload before Talent Show at 5:30 PM.' },
  { offload: '3',        neon: '7:00–7:15 PM',   jarrod: '7:15–7:30 PM',   breakPoint: 'After Talent Show ends (7 PM)',                    notes: 'Natural gap before DJ Sets at 8 PM.' },
  { offload: '4',        neon: '9:30–9:45 PM',   jarrod: '9:15–9:30 PM',   breakPoint: 'DJ transition — Peachy (9 PM)',                    notes: 'Jarrod goes first; Neon holds photo solo until 9:30.' },
  { offload: '5 (wrap)', neon: '11:30–11:50 PM', jarrod: '12:00–12:20 AM', breakPoint: 'End of night — wrap',                             notes: 'Both transfer all remaining cards to Nextcloud.' },
];
const offloadSun: OffloadWindow[] = [
  { offload: '1',        neon: '12:45–1:00 PM',  jarrod: '12:45–1:00 PM',  breakPoint: 'Post-Fursuit Games lunch break',                   notes: 'Both simultaneously. Floor Wars starts at 1 PM — must be done by then.' },
  { offload: '2',        neon: '4:15–4:30 PM',   jarrod: '4:00–4:15 PM',   breakPoint: 'Pre-Closing Ceremony window',                      notes: 'Jarrod goes first; both must be done before Closing Ceremony at 5 PM.' },
  { offload: '3',        neon: '7:15–7:30 PM',   jarrod: '7:30–7:45 PM',   breakPoint: 'After Closing Ceremony ends (7 PM)',               notes: 'Highest priority of the weekend — ceremony and auction footage.' },
  { offload: '4',        neon: '9:30–9:45 PM',   jarrod: '9:15–9:30 PM',   breakPoint: 'Dead Dog Dance — BeatSpark transition (9 PM)',     notes: 'Jarrod goes first; Neon holds photo solo until 9:30.' },
  { offload: '5 (wrap)', neon: '11:30–11:50 PM', jarrod: '12:00–12:20 AM', breakPoint: 'Convention wrap',                                  notes: 'Final offload of FurDU 2026. FurDU-issued cards returned to ConOps.' },
];

---
<Layout title="Media Guide | FurDU Media Team Hub" ogTitle="Media Guide | FurDU Media Team Hub" ogDescription="Complete guide for shooters: gear recommendations, offload workflow, glossary, deliverables, and event assignments.">
  <div class="max-w-[80vw] mx-auto px-4 py-8">

  <!-- ── PAGE HEADER ──────────────────────────────────────────────────── -->
  <div class="mb-8">
    <div class="flex items-center gap-2 text-sm text-furdu-muted mb-2">
      <a href="/" class="hover:text-furdu-teal transition-colors">Home</a>
      <span>/</span>
      <span class="text-white">Media Guide</span>
    </div>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-white mb-2">
      FurDU 2026 — Media Guide
    </h1>
    <div class="flex flex-wrap gap-3 text-sm text-furdu-muted">
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
          <rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 2v4"/><path d="M16 2v4"/>
        </svg>
        Fri 17 – Sun 19 April 2026
      </span>
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
        </svg>
        AEST (UTC+10)
      </span>
      <span id="live-clock-wrap" class="flex items-center gap-1.5 tabular-nums font-mono" style="display:none">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
        </svg>
        <span id="live-clock">--:--:-- AEST</span>
      </span>
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="3"/>
          <path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.636 5.636l2.122 2.122M16.242 16.242l2.121 2.121M5.636 18.364l2.122-2.122M16.242 7.757l2.121-2.121"/>
        </svg>
        Theme: Under the Sea / Beach
      </span>
    </div>
  </div>
  <!-- ── TABLE OF CONTENTS ──────────────────────────────────────────── -->
  <nav
    class="p-4 mb-8 sticky top-16 z-20 rounded-xl border border-furdu-teal/50 bg-gradient-to-br from-slate-950/80 to-slate-900/60 backdrop-blur-sm"
    aria-label="Table of contents"
    x-data="{
      active: 'team',
      sections: ['team','onboarding','gear','offload-schedule','offload-workflow','server','deliverables','glossary'],
      init() {
        const obs = new IntersectionObserver(entries => {
          entries.forEach(e => { if (e.isIntersecting) this.active = e.target.id; });
        }, { rootMargin: '-20% 0px -60% 0px', threshold: 0 });
        this.sections.forEach(id => { const el = document.getElementById(id); if (el) obs.observe(el); });
      }
    }"
  >
    <p class="text-xs font-semibold uppercase tracking-wider text-furdu-muted mb-3">On this page</p>
    <ol class="flex flex-wrap gap-x-1 gap-y-1">
      {([
        { href: '#team',             label: 'Media Team',       n: '1' },
        { href: '#onboarding',       label: 'Onboarding',       n: '2' },
        { href: '#gear',             label: 'Gear',             n: '3' },
        { href: '#offload-schedule', label: 'Offload Schedule', n: '4' },
        { href: '#offload-workflow', label: 'Offload Workflow', n: '5' },
        { href: '#server',           label: 'Server Structure', n: '6' },
        { href: '#deliverables',     label: 'Deliverables',     n: '7' },
        { href: '#glossary',         label: 'Glossary',         n: '8' },
      ]).map(l => (
        <li>
          <a
            href={l.href}
            :class={`active === '${l.href.slice(1)}' ? 'text-furdu-teal bg-cyan-900/30 border-furdu-teal/50' : 'text-furdu-muted hover:text-white border-transparent'`}
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border text-xs font-medium transition-colors duration-150"
          >
            <span
              :class={`active === '${l.href.slice(1)}' ? 'bg-furdu-teal text-furdu-bg' : 'bg-furdu-raised text-furdu-muted'`}
              class="inline-flex items-center justify-center w-4 h-4 rounded-full text-[10px] font-bold shrink-0 transition-colors duration-150"
            >{l.n}</span>
            {l.label}
          </a>
        </li>
      ))}
    </ol>
  </nav>
  <!-- ── MEDIA TEAM ────────────────────────────────────────────────────── -->
  <section class="mb-8" id="team">
    <h2 class="section-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" class="text-furdu-teal" viewBox="0 0 24 24">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      Media Team
    </h2>
    <div class="table-auto-scroll rounded-xl overflow-hidden border border-furdu-border">
      <table class="data-table">
        <thead>
          <tr>
            <th>Member</th><th>Role</th><th>Location</th><th>Capabilities</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="font-semibold text-white">Neon</td>
            <td>Photography</td>
            <td class="text-furdu-muted whitespace-nowrap">On-site (AEST, UTC+10)</td>
            <td><span class="badge-teal">Stills only</span></td>
          </tr>
          <tr>
            <td class="font-semibold text-white">Jarrod</td>
            <td>Photo + Video</td>
            <td class="text-furdu-muted whitespace-nowrap">On-site (AEST, UTC+10)</td>
            <td><span class="badge-violet">Stills and video</span></td>
          </tr>
          <tr>
            <td class="font-semibold text-white">Reo</td>
            <td>Media Team Lead</td>
            <td class="text-furdu-muted whitespace-nowrap">Philippines (PHT, UTC+8 · AEST −2h)</td>
            <td><span class="badge-orange">Culling, editing, publishing</span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── ONBOARDING ────────────────────────────────────────────────────── -->
  <section class="mb-8" id="onboarding">
    <h2 class="section-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" class="text-furdu-teal" viewBox="0 0 24 24">
        <path d="M12 22V12"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/>
        <path d="M12 2a4 4 0 0 1 4 4v6H8V6a4 4 0 0 1 4-4z"/>
      </svg>
      Pre-Event Onboarding
    </h2>

    <div class="space-y-4">

      <!-- Step 1 — Nextcloud -->
      <div class="card p-4 sm:p-5 flex gap-4">
        <div class="shrink-0 w-8 h-8 rounded-full bg-furdu-teal/20 border border-furdu-teal/40 flex items-center justify-center text-furdu-teal font-bold text-sm">1</div>
        <div class="space-y-1">
          <p class="font-semibold text-white">Check your email for media server account details</p>
          <p class="text-sm text-furdu-muted">Reo will have sent you a Nextcloud login via email before the event. Check your inbox (and spam folder). Your credentials give you access to the shared FurDU media server where all files are stored and reviewed in real-time.</p>
        </div>
      </div>

      <!-- Step 2 — Install Nextcloud -->
      <div class="card p-4 sm:p-5 flex gap-4">
        <div class="shrink-0 w-8 h-8 rounded-full bg-furdu-teal/20 border border-furdu-teal/40 flex items-center justify-center text-furdu-teal font-bold text-sm">2</div>
        <div class="space-y-1">
          <p class="font-semibold text-white">Install Nextcloud and sign in</p>
          <p class="text-sm text-furdu-muted">Download the <strong class="text-white">Nextcloud</strong> app on your phone and/or laptop. Sign in with the credentials from your email. Confirm you can browse the <code class="bg-furdu-bg px-1 rounded text-furdu-teal text-xs">FurDU/2026/</code> folder before the event starts — don't leave this until Day 1.</p>
        </div>
      </div>

      <!-- Step 3 — Camera clock -->
      <div class="card p-4 sm:p-5 flex gap-4">
        <div class="shrink-0 w-8 h-8 rounded-full bg-furdu-teal/20 border border-furdu-teal/40 flex items-center justify-center text-furdu-teal font-bold text-sm">3</div>
        <div class="space-y-2">
          <p class="font-semibold text-white">Sync your camera clock to Brisbane time (AEST)</p>
          <p class="text-sm text-furdu-muted">Correct timestamps ensure files sort together correctly when Reo culls across both shooters. Brisbane (AEST, UTC+10) does <strong class="text-white">not</strong> observe daylight saving — it is always UTC+10.</p>
          <div class="flex items-center gap-3 rounded-lg bg-furdu-bg px-4 py-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" class="text-furdu-teal shrink-0" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
            </svg>
            <span id="cam-clock" class="font-mono text-xl font-semibold text-white tabular-nums tracking-wide">--:--:--</span>
            <span class="text-furdu-muted text-xs">AEST (UTC+10) · Brisbane</span>
          </div>
          <p class="text-xs text-furdu-muted">Time is sourced from the server and ticks locally — accurate to within a second.</p>
          <p class="text-sm text-furdu-muted mt-1">Use <strong class="text-white">camera default file naming</strong> — do not rename files on import. Set the clock before Day 1 and check it again at your morning briefing each day.</p>
        </div>
      </div>

      <!-- Step 4 — Badge -->
      <div class="card p-4 sm:p-5 flex gap-4">
        <div class="shrink-0 w-8 h-8 rounded-full bg-furdu-teal/20 border border-furdu-teal/40 flex items-center justify-center text-furdu-teal font-bold text-sm">4</div>
        <div class="space-y-1">
          <p class="font-semibold text-white">Collect your media badge from ConOps</p>
          <p class="text-sm text-furdu-muted">On <strong class="text-white">Thursday or Friday</strong> before shooting starts, go to the ConOps desk and find a ConOps staff member. Let them know <strong class="text-white">Reo sent you</strong> — they will have your media badge ready to issue. Wear it visibly on your lanyard at all times during the event.</p>
        </div>
      </div>

      <!-- Step 5 — ConOps network -->
      <div class="card p-4 sm:p-5 flex gap-4">
        <div class="shrink-0 w-8 h-8 rounded-full bg-furdu-teal/20 border border-furdu-teal/40 flex items-center justify-center text-furdu-teal font-bold text-sm">5</div>
        <div class="space-y-1">
          <p class="font-semibold text-white">Join the ConOps network before the convention opens</p>
          <p class="text-sm text-furdu-muted">When you collect your badge from ConOps, also request the <strong class="text-white">ConOps Wi-Fi credentials</strong> (or ask about a wired ethernet drop at your offload station). Connect your laptop to the ConOps network and confirm Nextcloud syncs before Day 1 shooting starts. The venue public Wi-Fi is unreliable for large file transfers — ConOps network access ensures your offloads go through cleanly.</p>
          <div class="mt-2 flex items-start gap-2 rounded-lg bg-orange-950/40 border border-orange-700/40 px-3 py-2 text-sm text-orange-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" class="shrink-0 mt-0.5"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <span><strong class="text-orange-200">Do not share the ConOps Wi-Fi credentials with anyone.</strong> The ConOps network is shared by all staff — media file transfers alone use significant bandwidth. Every extra device on the network degrades transfer speeds for the whole team and risks missing an offload window.</span>
          </div>
        </div>
      </div>

      <!-- Step 6 — Offload prep -->
      <div class="card p-4 sm:p-5 flex gap-4">
        <div class="shrink-0 w-8 h-8 rounded-full bg-furdu-teal/20 border border-furdu-teal/40 flex items-center justify-center text-furdu-teal font-bold text-sm">6</div>
        <div class="space-y-1">
          <p class="font-semibold text-white">Prepare your offload setup</p>
          <p class="text-sm text-furdu-muted">Before the first shoot day: label all your cards clearly (<code class="bg-furdu-bg px-1 rounded text-furdu-teal text-xs">NEON-A</code> / <code class="bg-furdu-bg px-1 rounded text-furdu-teal text-xs">NEON-B</code> or <code class="bg-furdu-bg px-1 rounded text-furdu-teal text-xs">JARROD-A</code> / <code class="bg-furdu-bg px-1 rounded text-furdu-teal text-xs">JARROD-B</code>). Collect FurDU-issued cards from ConOps before the start of the con. Confirm your card reader is accessible. Know your offload windows from the <a href="#offload-schedule" class="text-furdu-teal hover:underline">Offload Schedule</a> below.</p>
        </div>
      </div>

      <!-- Step 7 — Read workflow -->
      <div class="card p-4 sm:p-5 flex gap-4">
        <div class="shrink-0 w-8 h-8 rounded-full bg-furdu-teal/20 border border-furdu-teal/40 flex items-center justify-center text-furdu-teal font-bold text-sm">7</div>
        <div class="space-y-1">
          <p class="font-semibold text-white">Read the Offload Workflow</p>
          <p class="text-sm text-furdu-muted">Before Day 1, read the full <a href="#offload-workflow" class="text-furdu-teal hover:underline">Offload Workflow</a> section of this guide. It covers the standard offload process, card rotation, backup procedures, and the fallback plan if ConOps is unavailable. You are responsible for your own offload — do not rely on other team members or ConOps staff to do it for you.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ── GEAR RECOMMENDATIONS ──────────────────────────────────────────── -->
  <section class="mb-8" id="gear">
    <h2 class="section-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" class="text-furdu-teal" viewBox="0 0 24 24">
        <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
        <circle cx="12" cy="13" r="3"/>
      </svg>
      Gear Recommendations
    </h2>

    <div x-data="{ tab: 'neon' }" class="card overflow-hidden">
      <!-- Tabs -->
      <div class="flex border-b border-furdu-border">
        {['neon', 'jarrod', 'both'].map(t => (
          <button
            class="flex-1 sm:flex-none px-4 py-3 text-sm font-semibold transition-colors duration-150"
            :class={`tab === '${t}' ? 'text-furdu-teal border-b-2 border-furdu-teal bg-cyan-900/20' : 'text-furdu-muted hover:text-white'`}
            @click={`tab = '${t}'`}
          >
            {t === 'neon' ? 'Neon (Canon R6 II)' : t === 'jarrod' ? 'Jarrod (Sony A7S III)' : 'Both Shooters'}
          </button>
        ))}
      </div>

      <!-- Neon -->
      <div x-show="tab === 'neon'" class="p-4 sm:p-6 space-y-6">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-furdu-muted mb-3">Lenses</p>
          <div class="table-auto-scroll rounded-xl overflow-hidden border border-furdu-border">
            <table class="data-table">
              <thead><tr><th>Lens</th><th>Use Case</th></tr></thead>
              <tbody>
                {neonLenses.map(r => (
                  <tr>
                    <td class="font-medium text-white whitespace-nowrap">{r.lens}</td>
                    <td class="text-furdu-muted text-sm">{r.use}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-furdu-muted mb-3">Lighting</p>
          <div class="table-auto-scroll rounded-xl overflow-hidden border border-furdu-border">
            <table class="data-table">
              <thead><tr><th>Light</th><th>Use Case</th></tr></thead>
              <tbody>
                {neonLights.map(r => (
                  <tr>
                    <td class="font-medium text-white whitespace-nowrap">{r.light}</td>
