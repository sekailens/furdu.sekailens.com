<script is:inline>
(function () {
  var isDev = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
  var offset = 0; // ms: server epoch − local epoch

  function syncServer() {
    if (isDev) return Promise.resolve();
    var t0 = Date.now();
    return fetch('/api/time')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        offset = data.epoch - Math.round((t0 + Date.now()) / 2);
      })
      ['catch'](function () { /* degrade to local time on error */ });
  }

  function serverNow() { return Date.now() + offset; }

  function render() {
    var ts   = serverNow();
    var aest = new Date(ts + 10 * 3600000);
    var pht  = new Date(ts +  8 * 3600000);
    var pad  = function (n) { return String(n).padStart(2, '0'); };
    var fmt  = function (d) {
      return pad(d.getUTCHours()) + ':' + pad(d.getUTCMinutes()) + ':' + pad(d.getUTCSeconds());
    };
    var el   = document.getElementById('live-clock');
    var wrap = document.getElementById('live-clock-wrap');
    var cam  = document.getElementById('cam-clock');
    if (el)   el.textContent  = fmt(aest) + ' AEST · ' + fmt(pht) + ' PHT';
    if (wrap) wrap.style.display = '';
    if (cam)  cam.textContent = fmt(aest);
  }

  // Re-sync at the next :00 second boundary, then repeat
  function scheduleSync() {
    var msUntilNextMinute = 60000 - (serverNow() % 60000);
    setTimeout(function () {
      syncServer().then(scheduleSync);
    }, msUntilNextMinute);
  }

  syncServer().then(function () {
    render();
    setInterval(render, 1000);
    scheduleSync();
  });
}());
</script>
