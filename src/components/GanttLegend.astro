---
import type { LEGEND_ITEMS } from '@/lib/gantt';
interface Props {
  items: typeof LEGEND_ITEMS;
}
const { items } = Astro.props;
---
<div class="flex flex-wrap gap-x-4 gap-y-2 mb-4 px-1">
  {items.map(l => (
    <div class="flex items-center gap-1.5 text-xs text-furdu-muted">
      <div class={`w-8 h-3.5 rounded border ${l.bg} ${l.border}`}></div>
      {l.label}
    </div>
  ))}
</div>
